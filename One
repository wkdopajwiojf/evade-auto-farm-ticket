------------------------------------------------------------------------
-- Safe Mode
------------------------------------------------------------------------
local safeMode = false
local safePos  = nil

local function holdAtPosition(pos)
    RunService:UnbindFromRenderStep("SafeModeHold")
    RunService:BindToRenderStep("SafeModeHold", Enum.RenderPriority.Character.Value + 1, function()
        if safeMode and not getgenv().TicketBusy and currentHRP and currentHRP.Parent then
            currentHRP.CFrame = pos
        end
    end)
end

local function monitorDowned()
    task.spawn(function()
        while safeMode do
            local char = lp.Character
            if char then
                if char:GetAttribute("State") == "Downed" then
                    print("[SafeMode] Downed detected → changing mode")
                    ChangeMode:FireServer(true)
                    task.wait(1)
                end
            end
            task.wait(0.2)
        end
    end)
end

local function monitorCharacterGone()
    task.spawn(function()
        local missingTimer = 0

        while safeMode do
            local char = lp.Character

            if char then
                missingTimer = 0  -- มีอยู่ → reset timer
            else
                missingTimer = missingTimer + 0.2  -- nil ไม่ว่ากรณีไหน → นับเลย
                if missingTimer >= 3 then
                    print("[SafeMode] Character gone > 3s → respawning")
                    local args = { [1] = true }
                    game:GetService("ReplicatedStorage").Events.Player.ChangePlayerMode:FireServer(unpack(args))
                    missingTimer = 0
                end
            end

            task.wait(0.2)
        end
    end)
end

Tab:CreateToggle({
    Name = "Safe Mode",
    CurrentValue = false,
    Callback = function(value)
        safeMode = value

        if safeMode then
            -- เริ่ม monitor character gone ทันที ไม่ขึ้นกับ HRP
            monitorCharacterGone()

            -- setup safePos + monitor downed เฉพาะตอนมี character
            task.spawn(function()
                local char = lp.Character or lp.CharacterAdded:Wait()
                local hrp  = char:WaitForChild("HumanoidRootPart")
                if not safeMode then return end
                currentCharacter = char
                currentHRP       = hrp
                safePos = currentHRP.CFrame * CFrame.new(0, 500, 0)
                currentCharacter:PivotTo(safePos)
                holdAtPosition(safePos)
                monitorDowned()
                print("[SafeMode] Enabled")
            end)
        else
            RunService:UnbindFromRenderStep("SafeModeHold")
            print("[SafeMode] Disabled")
        end
    end,
})

