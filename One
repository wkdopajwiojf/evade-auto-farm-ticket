------------------------------------------------------------------------
-- Helpers
------------------------------------------------------------------------
local function isBee(model)
    return model:IsA("Model") and model.Name:lower():find("bee")
end

local function getBeePosition(model)
    local part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    return part and part.Position
end

local function getModelPosition(model)
    local part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    return part and part.Position
end

------------------------------------------------------------------------
-- Follow bee until it despawns (smoothed velocity + auto ping prediction)
------------------------------------------------------------------------
local SMOOTH_FACTOR = 0.25  -- EMA weight สำหรับ velocity
local PING_SMOOTH   = 0.2   -- EMA weight สำหรับ ping, ต่ำ = กรอง spike ได้ดีกว่า

local smoothPing = lp:GetNetworkPing()  -- seed ด้วยค่าปิงแรก

local function followBeeUntilGone(model)
    if not currentHRP then
        getgenv().TicketBusy = false
        getgenv().BeeBusy    = false
        return
    end

    getgenv().TicketBusy = true
    getgenv().BeeBusy    = true

    local bindName  = "FollowBee_" .. tostring(model)
    local lastPos   = getBeePosition(model)
    local smoothVel = Vector3.new(0, 0, 0)

    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Character.Value + 1, function(dt)
        if not (model and model.Parent and currentHRP and currentHRP.Parent) then return end

        local currentPos = getBeePosition(model)
        if not currentPos then return end

        if lastPos and dt > 0 then
            -- smooth ping ทุก frame กัน spike
            smoothPing = smoothPing + (lp:GetNetworkPing() - smoothPing) * PING_SMOOTH

            -- raw velocity → smooth velocity
            local rawVel = (currentPos - lastPos) / dt
            smoothVel    = smoothVel:Lerp(rawVel, SMOOTH_FACTOR)

            -- วาปล่วงหน้าตาม ping จริง
            local predictedPos = currentPos + smoothVel * smoothPing
            currentHRP.CFrame  = CFrame.new(predictedPos)
        end

        lastPos = currentPos
    end)

    while model and model.Parent do
        if not currentHRP or not currentHRP.Parent then break end
        RunService.RenderStepped:Wait()
    end

    RunService:UnbindFromRenderStep(bindName)
    getgenv().TicketBusy = false
    getgenv().BeeBusy    = false
end

------------------------------------------------------------------------
-- Teleport to ticket until it despawns
------------------------------------------------------------------------
local function teleportUntilGone(model)
    -- FIX #1 (same pattern): reset both flags on early return
    if not currentHRP then
        getgenv().TicketBusy = false
        getgenv().BeeBusy    = false
        return
    end

    getgenv().TicketBusy = true

    local basePos = getModelPosition(model)
    if not basePos then
        getgenv().TicketBusy = false
        getgenv().BeeBusy    = false  -- FIX #2: restore BeeBusy reset that was incorrectly removed
        return
    end

    local targetCF = CFrame.new(basePos + Vector3.new(0, -1, 0))
    local bindName = "RuntimeTP_" .. tostring(model)

    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Character.Value + 1, function()
        if model and model.Parent and currentHRP and currentHRP.Parent then
            currentHRP.CFrame = targetCF
        end
    end)

    while model and model.Parent do
        if not currentHRP or not currentHRP.Parent then break end
        RunService.RenderStepped:Wait()
    end

    RunService:UnbindFromRenderStep(bindName)
    getgenv().TicketBusy = false
    getgenv().BeeBusy    = false  -- FIX #2
end

------------------------------------------------------------------------
-- Main farm loop
------------------------------------------------------------------------
local farmRunning = false

local function startFarm()
    while farmRunning do
        -- FIX #3: guard BeeBusy before spawning a new bee follower
        for _, model in ipairs(BEE_FOLDER:GetChildren()) do
            if not farmRunning then break end
            if isBee(model) and not getgenv().BeeBusy then
                task.spawn(followBeeUntilGone, model)
                task.wait(0.05)
            end
        end

        -- Collect tickets
        local snapshot = {}
        for _, model in ipairs(TARGET_FOLDER:GetChildren()) do
            if model:IsA("Model") and getModelPosition(model) then
                table.insert(snapshot, model)
            end
        end

        if #snapshot == 0 then
            task.wait(0.5)
            continue
        end

        for _, model in ipairs(snapshot) do
            if not farmRunning then break end
            teleportUntilGone(model)
            task.wait(0.1)
        end

        task.wait(0.3)
    end
end

Tab:CreateToggle({
    Name = "Auto honey",
    CurrentValue = false,
    Callback = function(value)
        farmRunning = value
        if farmRunning then
            task.spawn(startFarm)
        end
    end,
})

