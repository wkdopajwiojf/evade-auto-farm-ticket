------------------------------------------------------------------------
-- Safe Mode
------------------------------------------------------------------------

local function startHoldLoop()
    task.spawn(function()
        local wasBusy = false
        while safeMode do
            local isBusy = getgenv().TicketBusy
            if safePos and currentHRP and currentHRP.Parent then
                if isBusy then
                    -- กำลัง farm/revive อยู่ → แค่ track ว่า busy
                    wasBusy = true
                else
                    if wasBusy then
                        -- เพิ่งหมด busy → teleport กลับขึ้น safePos ใหม่ทันที
                        currentHRP.CFrame = safePos
                        wasBusy = false
                    else
                        -- ปกติ → hold ค้างไว้
                        currentHRP.CFrame = safePos
                    end
                end
            end
            task.wait(0.05)
        end
    end)
end

local function applySafePos(char, hrp)
    if not safeMode then return end
    currentCharacter = char
    currentHRP       = hrp

    if lastTicketPos then
        safePos = CFrame.new(lastTicketPos + Vector3.new(0, 300, 0))
    else
        safePos = CFrame.new(currentHRP.Position + Vector3.new(0, 300, 0))
    end

    currentHRP.CFrame = safePos
    print("[SafeMode] Position set →", safePos.Position)
end

local function monitorDowned()
    task.spawn(function()
        while safeMode do
            local char = lp.Character
            if char and char:GetAttribute("State") == "Downed" then
                print("[SafeMode] Downed detected → changing mode")
                ChangeMode:FireServer(true)
                task.wait(1)
            end
            task.wait(0.2)
        end
    end)
end

local function monitorCharacterGone()
    task.spawn(function()
        local missingTimer = 0
        while safeMode do
            if lp.Character then
                missingTimer = 0
            else
                missingTimer = missingTimer + 0.2
                if missingTimer >= 3 then
                    print("[SafeMode] Character gone > 3s → respawning")
                    local args = { [1] = true }
                    ReplicatedStorage.Events.Player.ChangePlayerMode:FireServer(unpack(args))
                    missingTimer = 0
                end
            end
            task.wait(0.2)
        end
    end)
end



Tab:CreateToggle({
    Name = "Safe Mode",
    CurrentValue = false,
    Callback = function(value)
        safeMode = value

        if safeMode then
            monitorCharacterGone()
            monitorDowned()
            startHoldLoop()

            task.spawn(function()
                local char = lp.Character or lp.CharacterAdded:Wait()
                local hrp  = char:WaitForChild("HumanoidRootPart")
                applySafePos(char, hrp)
            end)

            lp.CharacterAdded:Connect(function(char)
                if not safeMode then return end
                local hrp = char:WaitForChild("HumanoidRootPart")
                task.wait(0.1)
                applySafePos(char, hrp)
            end)

            print("[SafeMode] Enabled")
        else
            safePos = nil
            print("[SafeMode] Disabled")
        end
    end,
})

