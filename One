------------------------------------------------------------------------
-- Auto Revive
------------------------------------------------------------------------
local reviveRunning = false
local isReviving    = false

local function teleportToAndRevive(player)
    local char = player.Character
    if not char or not currentHRP then
        isReviving = false
        return
    end

    local bindName      = "ReviveTP_" .. player.Name
    local lastRevivePos = nil

    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Character.Value + 1, function()
        if char and char.Parent and currentHRP and currentHRP.Parent then
            local h = char:FindFirstChild("HumanoidRootPart")
            if h then
                currentHRP.CFrame = CFrame.new(h.Position)
                lastRevivePos     = h.Position
            end
        end
    end)

    -- spam revive แต่หยุดทันทีถ้าโดน carried ระหว่างชุบ
    while reviveRunning and char and char.Parent and isDowned(char) and not getCarried(char) do
        Interact:FireServer("Revive", nil, player.Name)
        Interact:FireServer("Revive", true, player.Name)
        task.wait(0.1)
    end

    RunService:UnbindFromRenderStep(bindName)

    if lastRevivePos then
        updateSafePosFromRevive(lastRevivePos)
    end

    task.wait(0.5)
    isReviving = false
end

local function handleTarget(player)
    isReviving = true

    local char = player.Character
    if not char then
        isReviving = false
        return
    end

    -- ถ้าไม่ถูก carry → รอ 3 วิ (ragdoll phase)
    if not getCarried(char) then
        local elapsed = 0
        while elapsed < 3 and reviveRunning do
            if not isDowned(char) then
                isReviving = false
                return
            end
            -- โดน carry ระหว่างรอ → ออกจาก loop ไปรอ carry หายแทน
            if getCarried(char) then break end
            task.wait(0.1)
            elapsed = elapsed + 0.1
        end
    end

    if not reviveRunning then
        isReviving = false
        return
    end

    -- ถ้าตอนนี้ถูก carry อยู่ → รอจน carry หาย
    while reviveRunning and isDowned(char) and getCarried(char) do
        task.wait(0.1)
    end

    if not reviveRunning or not isDowned(char) then
        isReviving = false
        return
    end

    -- เช็ค carried อีกครั้งก่อนวาป กัน race condition
    if getCarried(char) then
        isReviving = false
        return
    end

    teleportToAndRevive(player)
end

local function getNearestValidTarget()
    if not currentHRP then return nil end

    local nearest = nil
    local minDist = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character then
            local char = player.Character
            if isDowned(char) then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (hrp.Position - currentHRP.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = player
                    end
                end
            end
        end
    end

    return nearest
end

local function startReviveLoop()
    while reviveRunning do
        if not isReviving then
            local target = getNearestValidTarget()
            if target then
                task.spawn(handleTarget, target)
            end
        end
        task.wait(0.3)
    end
end

Tab:CreateToggle({
    Name = "Auto Revive",
    CurrentValue = false,
    Callback = function(value)
        reviveRunning = value
        if reviveRunning then
            task.spawn(startReviveLoop)
        end
    end,
})

