local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

local TARGET_FOLDER = workspace:WaitForChild("Game"):WaitForChild("Effects"):WaitForChild("Tickets")

local running = false

-- ดึงตำแหน่ง Model
local function getModelPosition(model)
    if model.PrimaryPart then
        return model.PrimaryPart.Position
    else
        local part = model:FindFirstChildWhichIsA("BasePart")
        if part then
            return part.Position
        end
    end
    return nil
end

local RunService = game:GetService("RunService")

local RunService = game:GetService("RunService")

local function teleportUntilGone(model)
    local char = lp.Character or lp.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    -- 🔒 snapshot ตำแหน่ง "ครั้งเดียว"
    local basePos
    if model.PrimaryPart then
        basePos = model.PrimaryPart.Position
    else
        local part = model:FindFirstChildWhichIsA("BasePart")
        if part then
            basePos = part.Position
        end
    end

    if not basePos then return end

    -- 👉 ปรับ Y -10
    local targetCF = CFrame.new(basePos + Vector3.new(0, -13, 0))

    local bindName = "RuntimeTP_" .. tostring(model)

    -- 💥 override ทุกเฟรม แต่ใช้ตำแหน่ง "เดิม"
    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Character.Value + 1, function()
        if model and model.Parent then
            hrp.CFrame = targetCF
        end
    end)

    -- 🔁 รอจน model หาย
    while model and model.Parent do
        RunService.RenderStepped:Wait()
    end

    RunService:UnbindFromRenderStep(bindName)
end

-- loop หลักแบบ snapshot
local function startFarm()
    while running do
        local snapshot = {}

        -- 1. สแกน + 2. บันทึกตำแหน่งทั้งหมด
        for _, model in pairs(TARGET_FOLDER:GetChildren()) do
            if model:IsA("Model") then
                local pos = getModelPosition(model)
                if pos then
                    table.insert(snapshot, model)
                end
            end
        end

        -- ถ้าไม่มีอะไร → รอสแกนใหม่
        if #snapshot == 0 then
            task.wait(0.5)
            continue
        end

        -- 3. วาปตามตำแหน่งที่บันทึกไว้
        for i, model in ipairs(snapshot) do
    		if not running then break end

    		teleportUntilGone(model)
    		task.wait(0.1)
		end

        -- 5. เคลียร์ snapshot (จริงๆ local อยู่แล้ว แค่ปล่อยให้ loop สร้างใหม่)
        table.clear(snapshot)

        task.wait(0.3)

    end
end

-- ===== RAYFIELD TOGGLE =====
Tab:CreateToggle({
    Name = "Auto honey",
    CurrentValue = false,
    Callback = function(Value)
        running = Value

        if running then
            task.spawn(startFarm)
        end
    end,
})
